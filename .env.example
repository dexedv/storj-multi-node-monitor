# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Discord webhook for daily/weekly/identity reminders
STORJ_DISCORD_WEBHOOK=https://discord.com/api/webhooks/XXXXXXXXXXX/YYYYYYYYYYYYYYYYYYYY

# Prometheus query endpoint (default localhost)
PROMETHEUS_URL=http://localhost:9090/api/v1/query
