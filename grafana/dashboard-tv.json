{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [{ "title": "🏠 Master", "type": "link", "url": "/d/storj-multi-node", "icon": "external link", "tags": [] }],
  "tags": ["storj", "storj-tv"],
  "title": "Storj TV-Dashboard",
  "uid": "storj-tv",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "style": "dark",
  "templating": { "list": [] },
  "panels": [
    { "type": "stat", "title": "", "id": 1, "gridPos": { "h": 5, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [{ "expr": "storj:fleet_min_status", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 1 }, { "color": "#00d4aa", "value": 2 }] }, "mappings": [{ "type": "value", "options": { "0": { "text": "🔴 PROBLEM" }, "1": { "text": "🟡 WARNUNG" }, "2": { "text": "🟢 ALL SYSTEMS NOMINAL" } } } ] } },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value", "justifyMode": "center" }
    },
    { "type": "stat", "title": "ONLINE", "id": 2, "gridPos": { "h": 7, "w": 6, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [{ "expr": "sum(storj_node_up)", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "#00d4aa", "value": 4 }] }, "unit": "none" } },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value", "justifyMode": "center" }
    },
    { "type": "stat", "title": "EARNINGS $", "id": 3, "gridPos": { "h": 7, "w": 6, "x": 6, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [{ "expr": "sum(storj_payout_current_month_usd)", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#f7c948" }, "unit": "currencyUSD", "decimals": 2 } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value", "justifyMode": "center" }
    },
    { "type": "stat", "title": "DISK %", "id": 4, "gridPos": { "h": 7, "w": 6, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [{ "expr": "100 * sum(storj_disk_used_bytes) / (sum(storj_disk_used_bytes) + sum(storj_disk_available_bytes) + sum(storj_disk_trash_bytes))", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "#00d4aa", "value": null }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 95 }] }, "unit": "percent", "decimals": 1 } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value", "justifyMode": "center" }
    },
    { "type": "stat", "title": "EGRESS LIVE", "id": 5, "gridPos": { "h": 7, "w": 6, "x": 18, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [{ "expr": "sum(storj:egress_rate_5m_bps)", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#00d4aa" }, "unit": "Bps", "decimals": 2 } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value", "justifyMode": "center" }
    },
    { "type": "timeseries", "title": "Egress / Ingress live", "id": 10, "gridPos": { "h": 9, "w": 16, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [
        { "expr": "sum(storj:egress_rate_5m_bps)", "refId": "A", "legendFormat": "Egress" },
        { "expr": "sum(storj:ingress_rate_5m_bps)", "refId": "B", "legendFormat": "Ingress" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "lineWidth": 3, "fillOpacity": 30, "gradientMode": "opacity", "lineInterpolation": "smooth", "showPoints": "never" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Egress" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#00d4aa" } }] },
          { "matcher": { "id": "byName", "options": "Ingress" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#5b8cff" } }] }
        ] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } }
    },
    { "type": "table", "title": "Pro Node", "id": 11, "gridPos": { "h": 9, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [
        { "expr": "storj_node_up", "refId": "A", "format": "table", "instant": true },
        { "expr": "storj_payout_current_month_usd", "refId": "B", "format": "table", "instant": true }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true }, "renameByName": { "node": "Node", "Value #A": "UP", "Value #B": "$" }, "indexByName": { "node": 0, "Value #A": 1, "Value #B": 2 } } }
      ],
      "fieldConfig": { "defaults": { "custom": { "align": "center" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "UP" }, "properties": [
            { "id": "mappings", "value": [{ "type": "value", "options": { "0": { "text": "❌", "color": "red" }, "1": { "text": "✓", "color": "#00d4aa" } } }] },
            { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }
          ] },
          { "matcher": { "id": "byName", "options": "$" }, "properties": [{ "id": "unit", "value": "currencyUSD" }, { "id": "decimals", "value": 2 }] }
        ] }
    }
  ]
}
