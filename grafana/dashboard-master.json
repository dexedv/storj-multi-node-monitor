{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "🌐 All-in-One", "type": "link", "url": "/d/depin-allinone", "icon": "external link", "tags": [] },
    { "title": "🌐 Storj Web-UI", "type": "link", "url": "http://localhost:14002", "icon": "external link", "targetBlank": true, "tags": [] },
    { "title": "Storj Stats (online)", "type": "link", "url": "https://stats.storjshare.io", "icon": "external link", "targetBlank": true, "tags": [] }
  ],
  "tags": ["storj"],
  "title": "Storj Node Monitor",
  "uid": "storj-multi-node",
  "schemaVersion": 39,
  "version": 12,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": { "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"], "time_options": ["15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"] },
  "timezone": "browser",
  "style": "dark",
  "templating": { "list": [] },
  "panels": [
    { "type": "stat", "title": "", "id": 999, "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "description": "Node-Gesamtstatus. Grün = up + QUIC OK + up-to-date.",
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [{ "expr": "storj:node_status_rank", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": {
        "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 1 }, { "color": "#00d4aa", "value": 2 }] },
        "mappings": [{ "type": "value", "options": {
          "0": { "text": "🔴 STORJ NODE OFFLINE — sofort prüfen", "color": "red" },
          "1": { "text": "🟡 Warnung — QUIC oder Software-Update Problem", "color": "yellow" },
          "2": { "text": "🟢 Storj Node läuft sauber — alle Subsystems OK", "color": "#00d4aa" }
        } }],
        "unit": "none"
      } },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },

    { "type": "row", "title": "📊 Übersicht", "id": 1000, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 3 }, "collapsed": false, "panels": [] },

    { "type": "gauge", "title": "Disk-Auslastung", "id": 1, "gridPos": { "h": 6, "w": 6, "x": 0, "y": 4 },
      "description": "Prozentuale Auslastung der allozierten Storj-Disk. Bei >95% blockt Storj neue Uploads.",
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [{ "expr": "storj:disk_used_percent", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "#00d4aa", "value": null }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 95 }] }, "unit": "percent", "min": 0, "max": 100, "decimals": 2 } },
      "options": { "showThresholdMarkers": true, "showThresholdLabels": true, "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    { "type": "stat", "title": "Belegter Speicher", "id": 2, "gridPos": { "h": 6, "w": 5, "x": 6, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [
        { "expr": "storj_disk_used_bytes", "refId": "A", "legendFormat": "belegt" },
        { "expr": "storj_disk_trash_bytes", "refId": "B", "legendFormat": "trash" },
        { "expr": "storj_disk_available_bytes", "refId": "C", "legendFormat": "frei" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "text" }] } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "belegt" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#5b8cff" } }] },
          { "matcher": { "id": "byName", "options": "trash" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#ffb84d" } }] },
          { "matcher": { "id": "byName", "options": "frei" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#00d4aa" } }] }
        ] },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value_and_name", "orientation": "horizontal", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    { "type": "stat", "title": "Disk voll in", "id": 3, "gridPos": { "h": 6, "w": 3, "x": 11, "y": 4 },
      "description": "Forecast wann die allozierte Disk voll ist, basierend auf Wachstumsrate der letzten 6h. Sinnvoll erst nach mehreren Stunden Datensammlung.",
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [{ "expr": "clamp_min(storj:disk_full_in_days, 0)", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 30 }, { "color": "#00d4aa", "value": 90 }] }, "unit": "d", "decimals": 0 } },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value", "justifyMode": "center" }
    },
    { "type": "stat", "title": "Einnahmen (Monat)", "id": 4, "gridPos": { "h": 6, "w": 5, "x": 14, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [
        { "expr": "storj_payout_current_month_usd", "refId": "A", "legendFormat": "aktuell" },
        { "expr": "storj:earnings_forecast_total_usd", "refId": "B", "legendFormat": "Forecast" },
        { "expr": "storj_payout_current_month_usd * scalar(storj_token_price_eur) / scalar(storj_token_price_usd)", "refId": "C", "legendFormat": "in EUR" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#f7c948" }, "unit": "currencyUSD", "decimals": 2 },
        "overrides": [
          { "matcher": { "id": "byFrameRefID", "options": "B" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#00d4aa" } }] },
          { "matcher": { "id": "byFrameRefID", "options": "C" }, "properties": [{ "id": "unit", "value": "currencyEUR" }] }
        ] },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name", "orientation": "horizontal", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    { "type": "stat", "title": "Held + Vormonat", "id": 5, "gridPos": { "h": 6, "w": 5, "x": 19, "y": 4 },
      "description": "75% wird die ersten 9 Monate zurückgehalten, dann schrittweise freigegeben. Volle Auszahlung erst nach 15 Monaten ohne Disqualifizierung.",
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [
        { "expr": "storj_payout_current_held_usd", "refId": "A", "legendFormat": "Held aktuell" },
        { "expr": "storj_payout_previous_month_usd", "refId": "B", "legendFormat": "Vormonat" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#ffb84d" }, "unit": "currencyUSD", "decimals": 2 },
        "overrides": [
          { "matcher": { "id": "byFrameRefID", "options": "B" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "text" } }] }
        ] },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value_and_name", "orientation": "horizontal", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },

    { "type": "row", "title": "⚡ Live-Aktivität & System", "id": 1001, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 }, "collapsed": false, "panels": [] },

    { "type": "stat", "title": "Egress live (5m)", "id": 10, "gridPos": { "h": 4, "w": 4, "x": 0, "y": 11 },
      "description": "Aktuelle Egress-Rate (Daten die zu Kunden raus gehen). 5-Minuten-Durchschnitt.",
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [{ "expr": "sum(storj:egress_rate_5m_bps)", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#00d4aa" }, "unit": "Bps", "decimals": 2 } },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value" }
    },
    { "type": "stat", "title": "Ingress live (5m)", "id": 11, "gridPos": { "h": 4, "w": 4, "x": 4, "y": 11 },
      "description": "Aktuelle Ingress-Rate (neue Daten die auf die Disk geschrieben werden). 5-Minuten-Durchschnitt.",
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [{ "expr": "sum(storj:ingress_rate_5m_bps)", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#5b8cff" }, "unit": "Bps", "decimals": 2 } },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value" }
    },
    { "type": "stat", "title": "Bandbreite (Monat)", "id": 12, "gridPos": { "h": 4, "w": 4, "x": 8, "y": 11 },
      "description": "Total Bandbreite seit Monatsbeginn (Ingress + Egress kombiniert).",
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [{ "expr": "storj_bandwidth_used_bytes", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#a259ff" }, "unit": "bytes", "decimals": 2 } },
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    { "type": "stat", "title": "Uptime", "id": 13, "gridPos": { "h": 4, "w": 4, "x": 12, "y": 11 },
      "description": "% der Zeit, in der die Node antwortet. 24h/7d/30d Fenster.",
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [
        { "expr": "storj:uptime_24h_percent", "refId": "A", "legendFormat": "24h" },
        { "expr": "storj:uptime_7d_percent", "refId": "B", "legendFormat": "7d" },
        { "expr": "storj:uptime_30d_percent", "refId": "C", "legendFormat": "30d" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 95 }, { "color": "#00d4aa", "value": 99 }] }, "unit": "percent", "decimals": 2 } },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value_and_name", "orientation": "vertical", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    { "type": "stat", "title": "Host CPU", "id": 14, "gridPos": { "h": 4, "w": 4, "x": 16, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [{ "expr": "100 * (1 - avg(rate(windows_cpu_time_total{mode=\"idle\"}[2m])))", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "#00d4aa", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] }, "unit": "percent", "decimals": 1, "min": 0, "max": 100 } },
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    { "type": "stat", "title": "Host RAM", "id": 15, "gridPos": { "h": 4, "w": 4, "x": 20, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [
        { "expr": "100 * (1 - windows_memory_available_bytes / windows_cs_physical_memory_bytes)", "refId": "A", "legendFormat": "%" },
        { "expr": "windows_memory_available_bytes", "refId": "B", "legendFormat": "frei" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "#00d4aa", "value": null }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 95 }] }, "unit": "percent", "decimals": 1, "min": 0, "max": 100 },
        "overrides": [{ "matcher": { "id": "byFrameRefID", "options": "B" }, "properties": [{ "id": "unit", "value": "bytes" }, { "id": "decimals", "value": 1 }, { "id": "color", "value": { "mode": "fixed", "fixedColor": "text" } }] }] },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value_and_name", "orientation": "horizontal", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },

    { "type": "row", "title": "💾 Geschrieben (Storj-Ingress)", "id": 1002, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 }, "collapsed": false, "panels": [] },

    { "type": "stat", "title": "Letzte 10 min", "id": 20, "gridPos": { "h": 4, "w": 4, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [{ "expr": "sum(increase(storj_satellite_ingress_bytes[10m]))", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#5b8cff" }, "unit": "bytes", "decimals": 2 } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value" }
    },
    { "type": "stat", "title": "Letzte 1 h", "id": 21, "gridPos": { "h": 4, "w": 4, "x": 4, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [{ "expr": "sum(increase(storj_satellite_ingress_bytes[1h]))", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#5b8cff" }, "unit": "bytes", "decimals": 2 } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value" }
    },
    { "type": "stat", "title": "Letzte 5 h", "id": 22, "gridPos": { "h": 4, "w": 4, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [{ "expr": "sum(increase(storj_satellite_ingress_bytes[5h]))", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#5b8cff" }, "unit": "bytes", "decimals": 2 } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value" }
    },
    { "type": "stat", "title": "Letzte 10 h", "id": 23, "gridPos": { "h": 4, "w": 4, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [{ "expr": "sum(increase(storj_satellite_ingress_bytes[10h]))", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#5b8cff" }, "unit": "bytes", "decimals": 2 } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value" }
    },
    { "type": "stat", "title": "Letzte 24 h", "id": 24, "gridPos": { "h": 4, "w": 4, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [{ "expr": "sum(increase(storj_satellite_ingress_bytes[24h]))", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#00d4aa" }, "unit": "bytes", "decimals": 2 } },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value" }
    },
    { "type": "stat", "title": "Schreib-Rate live", "id": 25, "gridPos": { "h": 4, "w": 4, "x": 20, "y": 16 },
      "description": "Aktuelle Schreib-Rate auf die Disk (5m-Durchschnitt). Identisch zu Ingress oben.",
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [{ "expr": "sum(storj:ingress_rate_5m_bps)", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#a259ff" }, "unit": "Bps", "decimals": 2 } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value" }
    },

    { "type": "row", "title": "🛰️ Satelliten-Scores", "id": 1003, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 }, "collapsed": false, "panels": [] },

    { "type": "table", "title": "Reputation pro Satellit", "id": 30, "gridPos": { "h": 8, "w": 24, "x": 0, "y": 21 },
      "description": "Audit-/Suspension-/Online-Score pro Satellit. < 0.95 = Suspension droht, < 0.85 = Disqualifizierungs-Risiko. Plus Traffic-Aufteilung Ingress/Egress.",
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [
        { "expr": "storj_satellite_audit_score", "refId": "A", "format": "table", "instant": true },
        { "expr": "storj_satellite_suspension_score", "refId": "B", "format": "table", "instant": true },
        { "expr": "storj_satellite_online_score", "refId": "C", "format": "table", "instant": true },
        { "expr": "storj_satellite_ingress_bytes", "refId": "D", "format": "table", "instant": true },
        { "expr": "storj_satellite_egress_bytes", "refId": "E", "format": "table", "instant": true }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true, "satellite_id": true, "node": true }, "renameByName": { "satellite": "Satellit", "Value #A": "Audit", "Value #B": "Suspension", "Value #C": "Online", "Value #D": "Ingress (Monat)", "Value #E": "Egress (Monat)" }, "indexByName": { "satellite": 0, "Value #A": 1, "Value #B": 2, "Value #C": 3, "Value #D": 4, "Value #E": 5 } } }
      ],
      "fieldConfig": { "defaults": { "custom": { "align": "center", "filterable": true } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "Audit|Suspension|Online" }, "properties": [
            { "id": "unit", "value": "percentunit" }, { "id": "decimals", "value": 4 }, { "id": "min", "value": 0.85 }, { "id": "max", "value": 1 },
            { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
            { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.95 }, { "color": "#00d4aa", "value": 0.99 }] } }
          ] },
          { "matcher": { "id": "byRegexp", "options": "Ingress|Egress" }, "properties": [{ "id": "unit", "value": "bytes" }, { "id": "decimals", "value": 2 }] },
          { "matcher": { "id": "byName", "options": "Satellit" }, "properties": [{ "id": "custom.width", "value": 150 }] }
        ]
      }
    },

    { "type": "row", "title": "📈 Verläufe", "id": 1004, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 }, "collapsed": false, "panels": [] },

    { "type": "timeseries", "title": "Disk-Wachstum", "id": 40, "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "description": "Wie wächst dein Disk-Verbrauch über Zeit. Aufgeteilt nach belegt/trash.",
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [
        { "expr": "storj_disk_used_bytes", "refId": "A", "legendFormat": "belegt" },
        { "expr": "storj_disk_trash_bytes", "refId": "B", "legendFormat": "trash" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 25, "gradientMode": "opacity", "lineInterpolation": "smooth", "showPoints": "never", "stacking": { "mode": "normal", "group": "A" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "belegt" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#5b8cff" } }] },
          { "matcher": { "id": "byName", "options": "trash" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#ffb84d" } }] }
        ] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "mean"] }, "tooltip": { "mode": "multi" } }
    },
    { "type": "timeseries", "title": "Earnings (Monat) — USD", "id": 41, "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [
        { "expr": "storj_payout_current_month_usd", "refId": "A", "legendFormat": "Aktuell USD" },
        { "expr": "storj:earnings_forecast_total_usd", "refId": "B", "legendFormat": "Forecast Monatsende" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 25, "gradientMode": "opacity", "lineInterpolation": "smooth", "showPoints": "never" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Aktuell USD" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#f7c948" } }] },
          { "matcher": { "id": "byName", "options": "Forecast Monatsende" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#00d4aa" } }, { "id": "custom.lineStyle", "value": { "dash": [10,10], "fill": "dash" } }] }
        ] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } }
    },
    { "type": "timeseries", "title": "Egress / Ingress live", "id": 42, "gridPos": { "h": 8, "w": 12, "x": 0, "y": 38 },
      "datasource": { "type": "prometheus", "uid": "bfltclibp84xsf" },
      "targets": [
        { "expr": "sum(storj:egress_rate_5m_bps)", "refId": "A", "legendFormat": "Egress" },
        { "expr": "sum(storj:ingress_rate_5m_bps)", "refId": "B", "legendFormat": "Ingress" }
      ],
